          "mode": "multi"
        }
      },
      "targets": [
        {
          "alias": "Anomaly (0=Normal, 1=Anomaly)",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT is_anomaly FROM ai_predictions WHERE $timeFilter",
          "refId": "A"
