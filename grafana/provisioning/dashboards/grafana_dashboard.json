{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "Select your InfluxDB data source",
      "type": "datasource",
      "pluginId": "influxdb"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "title": "System Metrics (Linux Container)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { 
          "datasource": { "uid": "${DS_INFLUXDB}" },
          "query": "SELECT (100 - usage_idle) FROM \"cpu\" WHERE $timeFilter", 
          "alias": "CPU %" 
        },
        { 
          "datasource": { "uid": "${DS_INFLUXDB}" },
          "query": "SELECT used_percent FROM \"mem\" WHERE $timeFilter", 
          "alias": "RAM %" 
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      }
    },
    {
      "title": "Network Traffic (Bytes Recv)",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { 
          "datasource": { "uid": "${DS_INFLUXDB}" },
          "query": "SELECT non_negative_derivative(mean(\"bytes_recv\"), 1s) FROM \"net\" WHERE $timeFilter GROUP BY time($__interval) FILL(null)", 
          "alias": "Network In" 
        }
      ]
    },
    {
      "title": "AI Anomaly Detection Status",
      "type": "state-timeline",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "targets": [
        { 
          "datasource": { "uid": "${DS_INFLUXDB}" },
          "query": "SELECT \"is_anomaly\" FROM \"ai_predictions\" WHERE $timeFilter", 
          "alias": "AI Status" 
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 70 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 36,
  "style": "dark",
  "title": "AI Infrastructure Monitoring - Final",
  "uid": "aise_final_01",
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s"
}