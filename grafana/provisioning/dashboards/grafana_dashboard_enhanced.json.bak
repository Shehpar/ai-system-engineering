{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Real-time Anomaly Detection Dashboard with Latency, Throughput & Drift Monitoring",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": 1,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "description": "Real-time CPU and Memory usage trends",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "alias": "CPU Usage %",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT (100 - usage_idle) as cpu_usage FROM cpu WHERE $timeFilter",
          "refId": "A"
        },
        {
          "alias": "Memory Usage %",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT used_percent as mem_usage FROM mem WHERE $timeFilter",
          "refId": "B"
        }
      ],
      "title": "System Metrics - CPU & Memory",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "description": "Network traffic analysis",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "alias": "Network In (Bytes/s)",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT non_negative_derivative(mean(bytes_recv), 1s) FROM net WHERE $timeFilter GROUP BY time($__interval) FILL(null)",
          "refId": "A"
        },
        {
          "alias": "Network Out (Bytes/s)",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT non_negative_derivative(mean(bytes_sent), 1s) FROM net WHERE $timeFilter GROUP BY time($__interval) FILL(null)",
          "refId": "B"
        }
      ],
      "title": "Network Traffic Analysis",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "description": "Real-time anomaly predictions from ML model",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "fillOpacity": 70,
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 0,
        "y": 9
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "alias": "Anomaly (0=Normal, 1=Anomaly)",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT is_anomaly FROM ai_predictions WHERE $timeFilter",
          "refId": "A"
        }
      ],
      "title": "Real-Time Anomaly Predictions",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "description": "Model inference latency in milliseconds",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 70,
            "lineWidth": 2
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 8,
        "y": 9
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "alias": "Prediction Latency (ms)",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT prediction_latency_ms FROM ai_predictions WHERE $timeFilter",
          "refId": "A"
        }
      ],
      "title": "Prediction Latency (Target: <5s)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "description": "Anomaly score from ML model (0=Normal, 1=Anomaly)",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 70,
            "lineWidth": 2
          },
          "max": 1,
          "min": -1
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 9
      },
      "id": 5,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "alias": "Anomaly Score",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT anomaly_score FROM ai_predictions WHERE $timeFilter",
          "refId": "A"
        }
      ],
      "title": "Anomaly Score Distribution",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "description": "Count of anomalies detected over time (throughput)",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "alias": "Anomalies Detected",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT count(is_anomaly) FROM ai_predictions WHERE is_anomaly=1 AND $timeFilter GROUP BY time(1m) FILL(0)",
          "refId": "A"
        }
      ],
      "title": "Anomaly Detection Throughput (Anomalies/Minute)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "description": "Count of anomalies detected (drift indicator)",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 70,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "id": 7,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "alias": "Anomaly Count (Trend Indicator)",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT count(is_anomaly) FROM ai_predictions WHERE $timeFilter GROUP BY time(5m) FILL(0)",
          "refId": "A"
        }
      ],
      "title": "Anomaly Trend (Data Drift Indicator)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      },
      "description": "System performance and anomaly detection rate over time",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 70,
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "id": 8,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "alias": "Avg CPU Usage",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT (100 - mean(usage_idle)) as avg_cpu FROM cpu WHERE $timeFilter GROUP BY time($__interval) FILL(null)",
          "refId": "A"
        },
        {
          "alias": "Avg Memory Usage",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT mean(used_percent) as avg_mem FROM mem WHERE $timeFilter GROUP BY time($__interval) FILL(null)",
          "refId": "B"
        },
        {
          "alias": "Anomaly Rate (per min)",
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "SELECT count(is_anomaly) FROM ai_predictions WHERE is_anomaly=1 AND $timeFilter GROUP BY time(1m) FILL(0)",
          "refId": "C"
        }
      ],
      "title": "System Performance & Anomaly Rate",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": [
